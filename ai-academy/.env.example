# ─────────────────────────────────────────────────────────────────
# Unfold AI Academy — Environment Variables
# ─────────────────────────────────────────────────────────────────
#
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your key: get it from app.unfoldit.com → Organization → API Keys
# 3. Run any scenario: npm run full-academy
# ─────────────────────────────────────────────────────────────────

# Required — org-scoped API key from app.unfoldit.com
# Scopes needed: goals:create, goals:read, assessment:generate, assessment:score, analytics:read
UNFOLD_API_KEY=your_org_api_key_here

# Optional — override for self-hosted or staging environments
# UNFOLD_API_URL=https://api.unfoldit.com
