# ─────────────────────────────────────────────────────────────────
# Unfold AI Academy — Environment Variables
# cp .env.local.example .env.local
# ─────────────────────────────────────────────────────────────────

# Required for live data. Without this, the app runs in Demo Mode.
# Get your key at: app.unfoldit.com → Organization → API Keys
# Scopes needed: goals:create goals:read assessment:generate assessment:score analytics:read
UNFOLD_API_KEY=

# Optional — override the API URL (default: https://api.unfoldit.com)
# UNFOLD_API_URL=https://api.unfoldit.com
